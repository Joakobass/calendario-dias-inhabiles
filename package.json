  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/chai": "^4.3.16",
    "@types/express": "^4.17.21",
    "@types/mocha": "^10.0.7",
    "@types/node": "^20.14.2",
    "@types/supertest": "^6.0.2",
    "chai": "^4.4.1",
    "mocha": "^10.4.0",
    "rimraf": "^5.0.7",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.15.1",
    "typescript": "^5.4.5"
  },
  "packageManager": "pnpm@10.33.0"
}
