{
  "name": "calendario-dias-inhabiles",
  "version": "1.0.0",
  "description": "API de días inhábiles para Juzgado Nacional del Trabajo",
  "main": "dist/app.js",
  "scripts": {
    "dev": "tsnd --respawn --clear src/app.ts",
